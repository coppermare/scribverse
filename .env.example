# Canonical public URL (sitemap, OG). Production: https://scribverse.xyz
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# YouTube Data API v3 (metadata for transcripts)
# console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your-youtube-api-key

# Optional: rate limit POST /api/transcribe (per IP, in memory)
# TRANSCRIBE_RATE_LIMIT_MAX=30
# TRANSCRIBE_RATE_LIMIT_WINDOW_MS=3600000

# Transcripts: try youtube-transcript + server timedtext; often empty on Vercel IPs.
# Supadata: optional YouTube fallback (mode=native — no AI). Required for TikTok, Instagram,
# X, and Facebook (transcript + metadata; mode=auto may use speech recognition per Supadata).
# https://supadata.ai/documentation/get-transcript
# SUPADATA_API_KEY=
# Optional: max ms to poll async Supadata jobs (native default 15000; auto default 60000)
# SUPADATA_JOB_POLL_MAX_MS=
